{
  "name": "site-analyzer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:cf": "wrangler pages dev --compatibility-date=2025-01-01 --compatibility-flag=nodejs_compat",
    "build": "next build",
    "build:cf": "npx @cloudflare/next-on-pages",
    "deploy": "npm run build:cf && wrangler pages deploy",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:init": "wrangler d1 execute site-analyzer-db --file=lib/db/schema.sql",
    "db:init:local": "wrangler d1 execute site-analyzer-db --local --file=lib/db/schema.sql"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "@react-pdf/renderer": "^4.3.2",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.2.0",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.6",
    "next": "15.3.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "typescript": "^5",
    "wrangler": "^4.71.0"
  }
}
